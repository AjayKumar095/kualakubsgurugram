<%- include('partials/header') %>
    <%- include('partials/enquireForm') %>

        <!-- Carousel Start -->
        <div class="container-fluid p-0 mb-5">
            <div class="owl-carousel header-carousel position-relative">
                <div class="owl-carousel-item position-relative">
                    <img class="img-fluid" src="/img/slide-img-1.jpg" alt="Best pre-school in gurugram">
                    <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center"
                        style="background: transparent">
                        <div class="container">
                            <div class="row justify-content-start">
                                <div class="col-sm-10 col-lg-8">
                                    <!-- <h5 class="text-primary text-uppercase mb-3 animated slideInDown">
                                    A PROMISING & POPULAR PRESCHOOL
                                    BACKED BY A RENOWNED EDUCATION GROUP
                                </h5> -->
                                    <h1 class="display-3 animated slideInDown" style="color: rgb(61, 6, 75);">A
                                        PROMISING &
                                        POPULAR
                                        PRESCHOOL
                                    </h1>
                                    <p class="fs-5 mb-4 pb-2" style="color: var(--primary);">A PROMISING & POPULAR
                                        PRESCHOOL
                                        BACKED BY A RENOWNED EDUCATION GROUP</p>
                                    <a href="/" class="btn btn-primary py-md-3 px-md-5 me-3 animated slideInLeft">GET
                                        STARTED</a>
                                    <button type="button" data-bs-toggle="modal" data-bs-target="#enquireModel"
                                        class="btn btn-light py-md-3 px-md-5 animated slideInRight">ENQUIR
                                        NOW</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
        <!-- Carousel End -->

        <!-- Bootstrap 5 Responsive Section -->
        <section class="py-5 overflow-hidden">
            <div class="container">

                <div class="row justify-content-center">
                    <div class="col-lg-10">

                        <!-- Main Heading -->
                        <div class="mb-4">
                            <h2 class="fw-bold display-6" style="color: rgb(61, 6, 75);">
                                MAKING LEARNING MORE EFFECTIVE & JOYFUL…
                            </h2>
                        </div>

                        <!-- Description -->
                        <div class="mb-4">
                            <p class="text-secondary fs-5">
                                KUALAKUBS is a venture of Geeta Group of Institutions —
                                an established and renowned name in the Indian education
                                landscape since 1985 operating multiple reputed educational
                                institutions, preschools, K-12 schools, higher education
                                institutes and university.
                            </p>
                        </div>

                        <!-- Features -->
                        <div class="mb-4">

                            <div class="d-flex align-items-start mb-3">
                                <i class="bi bi-check-circle-fill  fs-4 me-3" style="color: var(--primary)"></i>

                                <h5 class="mb-0 fw-semibold">
                                    Infrastructure designed for child safety
                                </h5>
                            </div>

                            <div class="d-flex align-items-start mb-3">
                                <i class="bi bi-check-circle-fill fs-4 me-3" style="color: var(--primary)"></i>

                                <h5 class="mb-0 fw-semibold">
                                    Trained Staff
                                </h5>
                            </div>

                            <div class="d-flex align-items-start">
                                <i class="bi bi-check-circle-fill fs-4 me-3" style="color: var(--primary)"></i>

                                <h5 class="mb-0 fw-semibold">
                                    In App Updates
                                </h5>
                            </div>

                        </div>

                        <!-- Button -->
                        <div>
                            <a href="/about" class="btn btn-primary px-4 py-2">
                                About Us
                                <i class="bi bi-arrow-up-right ms-2"></i>
                            </a>
                        </div>

                    </div>
                </div>

            </div>
        </section>
        <!-- Bootstrap 5 Responsive Section end -->

        <!-- Bootstrap 5 Responsive Admission Open -->
        <section class="py-5 position-relative" style="background-color: #fdf5e6; overflow: hidden;">
            <div class="container py-5 mt-3">
