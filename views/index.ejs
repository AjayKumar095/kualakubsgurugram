        <!-- Stripe Sessions style Flex Carousel -->
        <style>
            .stripe-carousel-container {
                display: flex;
                width: 100%;
                height: 60vh;
                min-height: 400px;
                gap: 15px;
                padding: 20px 0;
            }

            .stripe-carousel-item {
                position: relative;
                flex: 1;
                border-radius: 24px;
                background-position: center;
                background-size: cover;
                background-repeat: no-repeat;
                transition: all 0.6s cubic-bezier(0.25, 1, 0.5, 1);
                cursor: pointer;
                overflow: hidden;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            }

            .stripe-carousel-item:hover {
                flex: 6;
                box-shadow: 0 15px 40px rgba(0, 0, 0, 0.2);
            }

            .stripe-carousel-item::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                right: 0;
                height: 50%;
                background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
                opacity: 0;
                transition: opacity 0.6s ease;
            }

            .stripe-carousel-item:hover::after {
                opacity: 1;
            }

            .stripe-carousel-content {
                position: absolute;
                bottom: 30px;
                left: 30px;
                right: 30px;
                z-index: 2;
                opacity: 0;
                transform: translateY(20px);
                transition: all 0.6s cubic-bezier(0.25, 1, 0.5, 1);
                color: white;
                white-space: nowrap;
            }

            .stripe-carousel-item:hover .stripe-carousel-content {
                opacity: 1;
                transform: translateY(0);
                transition-delay: 0.1s;
            }

            .stripe-carousel-title {
                font-size: 2rem;
                font-weight: 700;
                margin-bottom: 5px;
            }

            .stripe-carousel-desc {
                font-size: 1rem;
                opacity: 0.9;
            }

            @media (max-width: 768px) {
                .stripe-carousel-container {
                    flex-direction: column;
                    height: 80vh;
                }

                .stripe-carousel-item:hover {
                    flex: 3;
                }
            }
        </style>

