            <div class="container py-5">
                <h2 class="fw-bold mb-5 text-center text-md-start px-md-4" style="color: rgb(61, 6, 75);">Why Kualakubs
                    Preschool ?</h2>

                <div class="row g-4 justify-content-center">
                    <!-- Column 1 -->
                    <div class="col-md-6 col-lg-5">

                        <div class="card mb-4 text-center border-2 shadow-sm wow fadeInUp" data-wow-delay="0.1s"
                            style="background-color: rgba(250, 245, 220, 0.9); border-color: #8cc63f !important; border-radius: 15px 0 15px 0 !important;">
                            <div class="card-body py-4 px-3">
                                <h6 class="fw-bold" style="color: rgb(61, 6, 75);">WELL DESIGNED TEACHING METHODOLOGY
